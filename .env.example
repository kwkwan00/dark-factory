# =============================================================================
# WARNING: All values in this file are PLACEHOLDERS, not secure defaults.
# Copy to .env and replace every `<change-me>` before running in any
# non-local environment. Never commit a populated .env to git.
# =============================================================================

NEO4J_USER=neo4j
NEO4J_PASSWORD=<change-me>
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# PostgreSQL metrics store. Disabled by default so local tests don't need
# a running Postgres. In docker-compose the dark-factory service enables
# it and points at the `postgres` service.
POSTGRES_ENABLED=false
POSTGRES_USER=darkfactory
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=darkfactory_metrics

# Grafana admin credentials. The default docker-compose admin/admin is
# ONLY safe on a private local network — change both before exposing.
GRAFANA_USER=admin
GRAFANA_PASSWORD=<change-me>

# Pipeline tuning overrides (optional; normally set via config.toml or the
# Settings tab). These env vars, if set, take precedence at startup.
# MAX_PARALLEL_FEATURES=4
# MAX_PARALLEL_SPECS=4
# MAX_SPEC_HANDOFFS=5
# MAX_CODEGEN_HANDOFFS=50
# SPEC_EVAL_THRESHOLD=0.8
# ENABLE_SPEC_DECOMPOSITION=true
# MAX_SPECS_PER_REQUIREMENT=12
# MAX_RECONCILIATION_TURNS=50
# RECONCILIATION_TIMEOUT_SECONDS=1800

# Semantic requirement dedup — cosine similarity above which two
# requirements from different uploaded documents are treated as the
# same and collapsed into one canonical entry before the Spec stage
# runs. 0.90 is conservative; raise to tighten clusters, lower to
# catch more paraphrases. Dedup is always on when the embedding
# service is reachable; there is no "enable" toggle because it's a
# correctness guarantee, not an optimisation.
# REQUIREMENT_DEDUP_THRESHOLD=0.90

# DeepEval judge model — override if gpt-5.4 isn't enabled on your OpenAI account
# EVAL_MODEL=gpt-5.1

# Claude Agent SDK default timeout — per-invocation ceiling for any
# deep-agent call (codegen, reconciliation, rich-doc extraction, E2E).
# Override per call site via tool args; this is just the default.
# DEEP_AGENT_TIMEOUT_SECONDS=600

# Claude Agent SDK verbose stderr. When set to 1/true/yes/on, the
# underlying Node CLI is spawned with ``--debug-to-stderr`` so it
# emits detailed startup, transport, and protocol-state lines on its
# stderr. Our per-invocation callback captures those lines (subject
# to the 200-line / 16 KiB buffer caps) and dumps them via
# ``log.error(deep_agent_failed, stderr_tail=…)`` whenever the
# subprocess crashes — giving operators real diagnostic info instead
# of the SDK's "Check stderr output for details" placeholder. Leave
# unset for normal runs; flip on while investigating a silent exit.
# DEEP_AGENT_DEBUG_STDERR=1

# Phase 6 — End-to-End validation via Playwright. Runs AFTER
# reconciliation completes non-errored. Browser binaries for all
# three engines are pre-installed in the Docker image, so the
# default matrix ships fully functional. Toggle off for runs that
# definitely won't produce a web app (pure CLI/library projects).
# ENABLE_E2E_VALIDATION=true
# MAX_E2E_TURNS=40
# E2E_TIMEOUT_SECONDS=1200
# E2E_BROWSERS=chromium,firefox,webkit

# Episodic memory (Stage 3 of procedural memory). After every
# feature swarm the orchestrator synthesises a narrative Episode
# via a small LLM call, embeds it with text-embedding-3-large, and
# stores it in Neo4j + Qdrant so future Planners can recall past
# trajectories via recall_episodes. Costs ~1k LLM tokens per
# feature. Disable if you're running single-shot features that
# never recur and the summarisation cost isn't worth the temporal
# reasoning layer.
# ENABLE_EPISODIC_MEMORY=true

# Memory write-time dedup threshold (Tier A). Before creating a
# new Pattern / Mistake / Solution / Strategy, the repository
# embeds the candidate and cosine-matches against same-type
# same-feature memories. Matches above this threshold get
# boosted instead of duplicated. Higher than the requirement
# dedup threshold (0.90) because memory false-positives are
# harder to untangle than requirement false-positives. Set to
# 0.00 to disable dedup entirely (creates a new node on every
# record_* call, matching pre-Tier-A behaviour).
# MEMORY_DEDUP_THRESHOLD=0.92

# Multi-model routing — assign different Claude models to different roles.
# Omit to use the default ANTHROPIC_MODEL everywhere. Useful for balancing
# cost vs. capability: Haiku for planning/analysis, Sonnet for codegen.
# MODEL_PLANNER=claude-haiku-4-5-20251001
# MODEL_CODER=claude-sonnet-4-6
# MODEL_REVIEWER=claude-sonnet-4-6
# MODEL_TESTER=claude-sonnet-4-6
# MODEL_DEEP_ANALYSIS=claude-haiku-4-5-20251001
# MODEL_DEEP_CODEGEN=claude-sonnet-4-6
# MODEL_SPEC=claude-sonnet-4-6
# MODEL_INGEST=claude-haiku-4-5-20251001

# Storage backend — "local" (default) or "s3". When set to "s3",
# pipeline inputs and outputs are stored in an S3 bucket with run-id
# as the top-level folder:
#
#   s3://my-bucket/run-20260412-051047/input/meeting.docx
#   s3://my-bucket/run-20260412-051047/output/main.py
#
# Deep agents still operate on a local scratch directory; files are
# synced to/from S3 before and after each phase.
# Requires: pip install boto3  (or: uv pip install "ai-dark-factory[s3]")
# STORAGE_BACKEND=local
# S3_BUCKET=my-dark-factory-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=                    # for S3-compatible stores (MinIO, LocalStack)
# AWS_ACCESS_KEY_ID=                  # or use IAM role / instance profile
# AWS_SECRET_ACCESS_KEY=
